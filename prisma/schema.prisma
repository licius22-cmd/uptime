generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Monitor {
  id            String   @id @default(uuid())
  url           String
  interval      Int      // Internal in minutes: 1, 3, 5, 10, 30, 60
  email         String
  lastCheckedAt DateTime @default(now()) // Start checking immediately
  status        String   @default("pending") // pending, up, down
  createdAt     DateTime @default(now())
}
