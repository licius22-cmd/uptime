generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Monitor {
  id                String           @id @default(uuid())
  name              String           @default("Monitor")
  url               String
  interval          Int              // Internal in minutes: 1, 3, 5, 10, 30, 60
  email             String           // Comma-separated list
  alertThreshold    Int              @default(1000)
  criticalThreshold Int              @default(2000)
  lastCheckedAt     DateTime         @default(now()) // Start checking immediately
  status            String           @default("pending") // pending, up, down
  createdAt         DateTime         @default(now())
  histories         MonitorHistory[]
}

model MonitorHistory {
  id           String   @id @default(uuid())
  monitorId    String
  responseTime Int
  status       String   // up, down
  createdAt    DateTime @default(now())
  monitor      Monitor  @relation(fields: [monitorId], references: [id], onDelete: Cascade)
}
